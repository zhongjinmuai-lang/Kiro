# ============================================================
# 🏢 开发商服务器部署环境变量
# 用法：cp .env.example .env && 修改为真实值
# 然后：docker compose --env-file .env up -d
# ============================================================

# HTTP/HTTPS 端口
HTTP_PORT=80
HTTPS_PORT=443

# 数据库
POSTGRES_USER=mu_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=mu_framework

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT 密钥（生产请使用 32+ 字符随机字符串）
JWT_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING_xxxxxxxxxx

# CORS 白名单（逗号分隔服务商/终端客户前端源）
# 留空则允许所有源（调试用，生产建议收紧）
# CORS_ALLOW_ORIGINS=https://provider-a.example.com,https://provider-b.example.com,https://family.example.com
CORS_ALLOW_ORIGINS=
