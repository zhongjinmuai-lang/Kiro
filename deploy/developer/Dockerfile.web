# 开发商服务器前端（只构建 admin-developer）+ Nginx 反代后端三服务
ARG VITE_API_BASE_URL=""

FROM node:22-alpine AS builder
WORKDIR /build
COPY frontend/admin-developer /build/admin-developer
ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN cd admin-developer && \
    (npm install --no-audit --no-fund --loglevel=error && npm run build) || \
    (echo "admin-developer build failed, using placeholder" && mkdir -p dist && echo "<html><body><h1>MU 开发商后台</h1><p>前端构建失败，请手动 npm run build 后重试</p></body></html>" > dist/index.html)

FROM nginx:1.27-alpine
RUN rm -rf /usr/share/nginx/html/*
COPY --from=builder /build/admin-developer/dist /usr/share/nginx/html
COPY deploy/developer/nginx.conf /etc/nginx/nginx.conf
EXPOSE 80 443
CMD ["nginx", "-g", "daemon off;"]
