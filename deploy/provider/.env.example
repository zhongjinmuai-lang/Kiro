# ============================================================
# 🏪 服务商服务器部署环境变量
# ============================================================

# 对外 HTTP/HTTPS 端口
HTTP_PORT=80
HTTPS_PORT=443

# 开发商 API 服务器地址（👈 必填）
# 构建时编译进前端，运行时 Nginx 也用它做反代
DEVELOPER_API_URL=https://api.mu-developer.com

# 前端构建时的 API 基地址
# 方案1（推荐）：走 Nginx 同域反代，留空即可
# VITE_API_BASE_URL=
# 方案2（跨域直连）：直接填开发商 URL（需开发商后端 CORS 放行）
# VITE_API_BASE_URL=https://api.mu-developer.com
VITE_API_BASE_URL=
