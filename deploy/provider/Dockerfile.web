# 服务商服务器：仅构建 admin-provider + Nginx 反代开发商 API
ARG VITE_API_BASE_URL=""

FROM node:22-alpine AS builder
WORKDIR /build
COPY frontend/admin-provider /build/admin-provider
ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN cd admin-provider && \
    (npm install --no-audit --no-fund --loglevel=error && npm run build) || \
    (echo "build failed" && mkdir -p dist && echo "<html><body><h1>MU 服务商后台</h1><p>前端构建失败</p></body></html>" > dist/index.html)

FROM nginx:1.27-alpine
RUN apk add --no-cache gettext
RUN rm -rf /usr/share/nginx/html/*
COPY --from=builder /build/admin-provider/dist /usr/share/nginx/html
COPY deploy/provider/nginx.conf.template /etc/nginx/nginx.conf.template
EXPOSE 80 443
# 启动时用 envsubst 替换 DEVELOPER_API_URL 为真实值
CMD sh -c "envsubst '\$DEVELOPER_API_URL' < /etc/nginx/nginx.conf.template > /etc/nginx/nginx.conf && nginx -g 'daemon off;'"
