{
  "name": "MU智能体",
  "appid": "com.mu.framework",
  "description": "MU全能智能体框架 - 多端统一移动端（UniApp X · Vue3标准语法 · 一次编译多端发布）",
  "versionName": "1.0.0",
  "versionCode": 100,
  "uni-app-x": {},
  "vueVersion": "3",

  "app": {
    "distribute": {
      "android": {
        "minSdkVersion": 21,
        "targetSdkVersion": 34,
        "permissions": [
          "android.permission.INTERNET",
          "android.permission.ACCESS_NETWORK_STATE",
          "android.permission.CAMERA",
          "android.permission.READ_EXTERNAL_STORAGE",
          "android.permission.WRITE_EXTERNAL_STORAGE",
          "android.permission.VIBRATE"
        ]
      },
      "ios": {
        "deploymentTarget": "12.0",
        "idfa": false
      }
    }
  },

  "h5": {
    "title": "MU智能体",
    "router": { "mode": "history", "base": "/" },
    "devServer": { "port": 5173, "https": false },
    "optimization": { "treeShaking": { "enable": true } }
  },

  "mp-weixin": {
    "appid": "",
    "setting": { "urlCheck": false, "es6": true, "minified": true },
    "usingComponents": true,
    "lazyCodeLoading": "requiredComponents"
  },

  "mp-alipay": {
    "appid": "",
    "component2": true,
    "enableNodeModuleBabelTransform": true
  },

  "mp-toutiao": {
    "appid": "",
    "setting": { "urlCheck": false, "es6": true, "minified": true },
    "usingComponents": true
  },

  "mp-xhs": {
    "appid": "",
    "setting": { "urlCheck": false, "es6": true, "minified": true }
  },

  "mp-harmony": {
    "appid": "",
    "description": "鸿蒙元服务（HarmonyOS Atomic Service）"
  },

  "mp-baidu": { "appid": "" },
  "mp-qq":    { "appid": "" },
  "mp-kuaishou": { "appid": "" }
}
